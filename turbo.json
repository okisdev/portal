{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**"
      ],
      "env": [
        "AUTH_RESEND_KEY",
        "AUTH_SECRET",
        "DATABASE_URL",
        "STRIPE_KEY",
        "NEXT_PUBLIC_APP_URL",
        "WEBHOOK_VERIFY_TOKEN",
        "META_GRAPH_API_TOKEN",
        "WHATSAPP_PHONE_NUMBER_ID"
      ]
    },
    "check-types": {
      "dependsOn": [
        "^check-types"
      ]
    },
    "dev": {
      "persistent": true,
      "cache": false
    }
  }
}