## Event Management

### Event Dialog Component
```tsx
const eventFormSchema = z.object({
  title: z.string().min(1, 'Title is required'),
  description: z.string().optional(),
  location: z.string().optional(),
  startAt: z.date(),
  endAt: z.date(),
  isAllDay: z.boolean().default(false),
  isPublic: z.boolean().default(false),
  folderId: z.string(),
  participants: z.array(z.object({
    type: z.enum(['user', 'contact', 'external']),
    id: z.string().optional(),
    email: z.string().optional(),
    name: z.string().optional(),
    role: z.enum(['organizer', 'required', 'optional']).default('required'),
  })).default([]),
});

export function EventDialog({ open, onOpenChange, event, onSave }: EventDialogProps) {
  const form = useForm<z.infer<typeof eventFormSchema>>({
    resolver: zodResolver(eventFormSchema),
    defaultValues: {
      title: event?.title || '',
      description: event?.description || '',
      location: event?.location || '',
      startAt: event ? new Date(event.startAt) : new Date(),
      endAt: event ? new Date(event.endAt) : addHours(new Date(), 1),
      isAllDay: event?.isAllDay || false,
      isPublic: event?.isPublic || false,
      folderId: event?.folderId || '',
      participants: event?.participants || [],
    },
  });

  const { data: contacts } = api.contact.getAll.useQuery();
  const { data: users } = api.user.getTeamMembers.useQuery();

  const onSubmit = async (data: z.infer<typeof eventFormSchema>) => {
    await onSave({
      ...data,
      id: event?.id,
    });
    onOpenChange(false);
  };

  return (
    <Dialog open={open} onOpenChange={onOpenChange}>
      <DialogContent className="max-w-2xl">
        <DialogHeader>
          <DialogTitle>{event ? 'Edit Event' : 'Create Event'}</DialogTitle>
        </DialogHeader>

        <Form {...form}>
          <form onSubmit={form.handleSubmit(onSubmit)} className="space-y-4">
            <FormField
              control={form.control}
              name="title"
              render={({ field }) => (
                <FormItem>
                  <FormLabel>Title</FormLabel>
                  <FormControl>
                    <Input {...field} placeholder="Event title" />
                  </FormControl>
                  <FormMessage />
                </FormItem>
              )}
            />

            <div className="grid grid-cols-2 gap-4">
              <FormField
                control={form.control}
                name="startAt"
                render={({ field }) => (
                  <FormItem>
                    <FormLabel>Start Time</FormLabel>
                    <FormControl>
                      <DateTimePicker
                        value={field.value}
                        onChange={field.onChange}
                      />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />

              <FormField
                control={form.control}
                name="endAt"
                render={({ field }) => (
                  <FormItem>
                    <FormLabel>End Time</FormLabel>
                    <FormControl>
                      <DateTimePicker
                        value={field.value}
                        onChange={field.onChange}
                      />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />
            </div>

            <div className="flex items-center space-x-4">
              <FormField
                control={form.control}
                name="isAllDay"
                render={({ field }) => (
                  <FormItem className="flex items-center space-x-2">
                    <FormControl>
                      <Checkbox
                        checked={field.value}
                        onCheckedChange={field.onChange}
                      />
                    </FormControl>
                    <FormLabel className="text-sm font-normal">
                      All day
                    </FormLabel>
                  </FormItem>
                )}
              />

              <FormField
                control={form.control}
                name="isPublic"
                render={({ field }) => (
                  <FormItem className="flex items-center space-x-2">
                    <FormControl>
                      <Checkbox
                        checked={field.value}
                        onCheckedChange={field.onChange}
                      />
                    </FormControl>
                    <FormLabel className="text-sm font-normal">
                      Public event
                    </FormLabel>
                  </FormItem>
                )}
              />
            </div>

            <FormField
              control={form.control}
              name="location"
              render={({ field }) => (
                <FormItem>
                  <FormLabel>Location</FormLabel>
                  <FormControl>
                    <Combobox
                      value={field.value || ''}
                      onChange={field.onChange}
                      items={commonLocations}
                      placeholder="Select or enter location"
                      allowCustom
                    />
                  </FormControl>
                  <FormMessage />
                </FormItem>
              )}
            />

            <FormField
              control={form.control}
              name="description"
              render={({ field }) => (
                <FormItem>
                  <FormLabel>Description</FormLabel>
                  <FormControl>
                    <Textarea {...field} placeholder="Event description" />
                  </FormControl>
                  <FormMessage />
                </FormItem>
              )}
            />

            {/* Participants selection */}
            <ParticipantSelector
              participants={form.watch('participants')}
              onParticipantsChange={(participants) => 
                form.setValue('participants', participants)
              }
              contacts={contacts}
              users={users}
            />

            <div className="flex justify-end gap-2 pt-4">
              <Button 
                type="button" 
                variant="outline" 
                onClick={() => onOpenChange(false)}
              >
                Cancel
              </Button>
              <Button type="submit">
                {event ? 'Update Event' : 'Create Event'}
              </Button>
            </div>
          </form>
        </Form>
      </DialogContent>
    </Dialog>
  );
}
```

## Calendar Router

### tRPC Calendar Operations
```typescript
// server/routers/calendar.ts
import { z } from 'zod';
import { createTRPCRouter, protectedProcedure } from '@/server/trpc';
import { calendarEvent } from '@/drizzle/schema';
import { eq, and, gte, lte } from 'drizzle-orm';

const createEventSchema = z.object({
  title: z.string().min(1),
  description: z.string().optional(),
  location: z.string().optional(),
  startAt: z.date(),
  endAt: z.date(),
  isAllDay: z.boolean().default(false),
  isPublic: z.boolean().default(false),
  folderId: z.string().optional(),
  participants: z.array(z.any()).default([]),
});

export const calendarRouter = createTRPCRouter({
  // Get events for a date range
  getEvents: protectedProcedure
    .input(z.object({
      startDate: z.date(),
      endDate: z.date(),
      includePublic: z.boolean().default(true),
    }))
    .query(async ({ ctx, input }) => {
      const conditions = [
        gte(calendarEvent.startAt, input.startDate),
        lte(calendarEvent.endAt, input.endDate),
      ];

      // Include user's own events and public events
      if (input.includePublic) {
        conditions.push(
          or(
            eq(calendarEvent.userId, ctx.session.user.id),
            eq(calendarEvent.isPublic, true)
          )
        );
      } else {
        conditions.push(eq(calendarEvent.userId, ctx.session.user.id));
      }

      return ctx.db
        .select()
        .from(calendarEvent)
        .where(and(...conditions))
        .orderBy(calendarEvent.startAt);
    }),

  // Create a new event
  create: protectedProcedure
    .input(createEventSchema)
    .mutation(async ({ ctx, input }) => {
      const newEvent = await ctx.db.insert(calendarEvent).values({
        id: crypto.randomUUID(),
        userId: ctx.session.user.id,
        ...input,
        participants: input.participants.length > 0 
          ? JSON.stringify(input.participants) 
          : null,
        createdAt: new Date(),
        updatedAt: new Date(),
      }).returning();

      // Send calendar invitations to participants
      await sendEventInvitations(newEvent[0]);

      return newEvent[0];
    }),

  // Update an event
  update: protectedProcedure
    .input(z.object({
      id: z.string(),
      ...createEventSchema.partial(),
    }))
    .mutation(async ({ ctx, input }) => {
      const { id, ...updates } = input;
      
      const updatedEvent = await ctx.db
        .update(calendarEvent)
        .set({
          ...updates,
          participants: updates.participants 
            ? JSON.stringify(updates.participants) 
            : undefined,
          updatedAt: new Date(),
        })
        .where(and(
          eq(calendarEvent.id, id),
          eq(calendarEvent.userId, ctx.session.user.id)
        ))
        .returning();

      return updatedEvent[0];
    }),

  // Delete an event
  delete: protectedProcedure
    .input(z.object({ id: z.string() }))
    .mutation(async ({ ctx, input }) => {
      await ctx.db
        .delete(calendarEvent)
        .where(and(
          eq(calendarEvent.id, input.id),
          eq(calendarEvent.userId, ctx.session.user.id)
        ));

      return { success: true };
    }),

  // Get calendar statistics
  getStats: protectedProcedure
    .query(async ({ ctx }) => {
      const now = new Date();
      const startOfWeek = startOfWeek(now);
      const endOfWeek = endOfWeek(now);

      const [thisWeekEvents, upcomingEvents] = await Promise.all([
        ctx.db
          .select()
          .from(calendarEvent)
          .where(and(
            eq(calendarEvent.userId, ctx.session.user.id),
            gte(calendarEvent.startAt, startOfWeek),
            lte(calendarEvent.endAt, endOfWeek)
          )),
        ctx.db
          .select()
          .from(calendarEvent)
          .where(and(
            eq(calendarEvent.userId, ctx.session.user.id),
            gte(calendarEvent.startAt, now)
          ))
          .orderBy(calendarEvent.startAt)
          .limit(5),
      ]);

      return {
        thisWeekCount: thisWeekEvents.length,
        upcomingEvents,
      };
    }),
});
```

## Best Practices

### Event Organization
- Use clear, descriptive event titles
- Include location information for in-person events
- Set appropriate visibility (public/private)
- Add relevant participants with correct roles

### Calendar Views
- Provide multiple view options (month, week, day)
- Implement smooth navigation between periods
- Show appropriate event details for each view
- Handle overlapping events gracefully

### Performance
- Load events only for visible date ranges
- Implement efficient caching strategies
- Use virtual scrolling for large datasets
- Optimize drag-and-drop operations

### Integration
- Connect events with contacts and companies
- Link to task management system
- Support external calendar imports/exports
- Integrate with email for invitations