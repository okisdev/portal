# Calendar & Event Management

Portal provides comprehensive calendar functionality with event scheduling, meeting management, and team collaboration.

## Architecture

### Core Components
- `app/[locale]/dashboard/workspace/calendar/page.tsx`: Main calendar interface
- `components/dashboard/workspace/calendar/`: Calendar view components
- `components/shared/event-dialog.tsx`: Event creation and editing
- `components/shared/event-popover.tsx`: Quick event preview
- `server/routers/calendar.ts`: Calendar tRPC router
- `drizzle/schema.ts`: Calendar and event database schema

### Database Schema
```typescript
export const calendarEvent = pgTable('portal_calendar_event', {
  id: text().primaryKey().$defaultFn(() => crypto.randomUUID()),
  userId: text().notNull().references(() => user.id),
  title: text().notNull(),
  description: text(),
  location: text(),
  startAt: timestamp({ mode: 'date' }).notNull(),
  endAt: timestamp({ mode: 'date' }).notNull(),
  isAllDay: boolean().default(false),
  isPublic: boolean().default(false),
  folderId: text(), // For event categorization
  participants: text(), // JSON array of participant objects
  recurrenceRule: text(), // RRULE for recurring events
  metadata: text(), // Additional event data as JSON
  createdAt: timestamp({ mode: 'date' }).notNull().defaultNow(),
  updatedAt: timestamp({ mode: 'date' }).notNull().defaultNow(),
});

export const teamMeeting = pgTable('portal_team_meeting', {
  id: text().primaryKey().$defaultFn(() => crypto.randomUUID()),
  teamId: text().notNull().references(() => team.id),
  eventId: text().references(() => calendarEvent.id),
  title: text().notNull(),
  agenda: text(),
  meetingUrl: text(),
  recordingUrl: text(),
  notes: text(),
  createdAt: timestamp({ mode: 'date' }).notNull().defaultNow(),
  updatedAt: timestamp({ mode: 'date' }).notNull().defaultNow(),
});
