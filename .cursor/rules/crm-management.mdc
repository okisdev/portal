# CRM Management System

Portal's CRM system provides comprehensive management of contacts, companies, and team collaboration with advanced features for lead tracking, relationship management, and sales processes.

## Architecture

### Core Components
- `app/[locale]/dashboard/crm/`: CRM feature routes
- `components/dashboard/contact/`: Contact management components
- `server/routers/contact/`: Contact tRPC router
- `server/routers/company.ts`: Company management router
- `server/routers/team/`: Team collaboration router
- `server/helper/contact.ts`: Contact helper functions
- `drizzle/schema.ts`: CRM database schema

### Database Schema
```typescript
// Contact management
export const contact = pgTable('portal_contact', {
  id: text().primaryKey().$defaultFn(() => crypto.randomUUID()),
  name: text(), // Full name (computed field)
  firstName: text().notNull(),
  lastName: text().notNull(),
  email: text(),
  phone: text(),
  gender: text(),
  company: text(), // Company name (legacy field)
  companyId: text().references(() => company.id),
  jobTitle: text(),
  address: text(),
  city: text(),
  state: text(),
  country: text(),
  postalCode: text(),
  remark: text(),
  status: text('status').notNull().default('Lead'), // Lead, Prospect, Customer, etc.
  source: text(), // How they found us\n  assignedTo: text().references(() => user.id),\n  stripeCustomerId: text(),\n  createdBy: text().references(() => user.id),\n  joinedAt: timestamp({ mode: 'date' }),\n  createdAt: timestamp({ mode: 'date' }).notNull().defaultNow(),\n  updatedAt: timestamp({ mode: 'date' }).notNull().defaultNow(),\n  lastContactedAt: timestamp({ mode: 'date' }),\n  lastActivity: text('lastActivity'),\n  nextFollowUpAt: timestamp({ mode: 'date' }),\n  priority: text('priority').default('Medium'),\n  workExperience: text(),\n  currentRole: text(),\n  industry: text(),\n  skills: text(),\n  externalId: text(), // For external system integration\n});\n\n// Company management\nexport const company = pgTable('portal_company', {\n  id: text().primaryKey().$defaultFn(() => crypto.randomUUID()),\n  name: text().notNull(),\n  description: text(),\n  industry: text(),\n  size: text(), // Employee count range\n  website: text(),\n  address: text(),\n  city: text(),\n  state: text(),\n  country: text(),\n  postalCode: text(),\n  phone: text(),\n  email: text(),\n  status: text('status', { enum: ['active', 'inactive'] }).default('active'),\n  metadata: text(), // JSON for additional fields\n  createdAt: timestamp({ mode: 'date' }).notNull().defaultNow(),\n  updatedAt: timestamp({ mode: 'date' }).notNull().defaultNow(),\n});\n\n// Many-to-many relationship between companies and contacts\nexport const companyContact = pgTable('portal_company_contact', {\n  id: text().primaryKey().$defaultFn(() => crypto.randomUUID()),\n  companyId: text().notNull().references(() => company.id),\n  contactId: text().notNull().references(() => contact.id),\n  role: text(), // Role of contact at company\n  isPrimary: boolean().default(false), // Primary contact for company\n  startDate: timestamp({ mode: 'date' }),\n  endDate: timestamp({ mode: 'date' }),\n  createdAt: timestamp({ mode: 'date' }).notNull().defaultNow(),\n});\n\n// Team management\nexport const team = pgTable('portal_team', {\n  id: text().primaryKey().$defaultFn(() => crypto.randomUUID()),\n  name: text().notNull(),\n  description: text(),\n  type: text('type').default('sales'), // sales, support, marketing, etc.\n  leaderId: text().references(() => user.id),\n  isActive: boolean().default(true),\n  settings: text(), // JSON for team-specific settings\n  createdAt: timestamp({ mode: 'date' }).notNull().defaultNow(),\n  updatedAt: timestamp({ mode: 'date' }).notNull().defaultNow(),\n});\n```\n\n## Contact Management\n\n### Contact List Component\n```tsx\ninterface ContactListProps {\n  contacts: Contact[];\n  onContactSelect: (contact: Contact) => void;\n  onContactEdit: (contact: Contact) => void;\n  onContactDelete: (contactId: string) => void;\n}\n\nexport function ContactList({ \n  contacts, \n  onContactSelect, \n  onContactEdit, \n  onContactDelete \n}: ContactListProps) {\n  const [selectedContacts, setSelectedContacts] = useState<string[]>([]);\n  const [sortConfig, setSortConfig] = useState<{\n    key: keyof Contact;\n    direction: 'asc' | 'desc';\n  } | null>(null);\n\n  const sortedContacts = useMemo(() => {\n    if (!sortConfig) return contacts;\n\n    return [...contacts].sort((a, b) => {\n      const aValue = a[sortConfig.key];\n      const bValue = b[sortConfig.key];\n\n      if (aValue === null || aValue === undefined) return 1;\n      if (bValue === null || bValue === undefined) return -1;\n\n      if (aValue < bValue) {\n        return sortConfig.direction === 'asc' ? -1 : 1;\n      }\n      if (aValue > bValue) {\n        return sortConfig.direction === 'asc' ? 1 : -1;\n      }\n      return 0;\n    });\n  }, [contacts, sortConfig]);\n\n  const handleSort = (key: keyof Contact) => {\n    setSortConfig(current => ({\n      key,\n      direction: current?.key === key && current.direction === 'asc' ? 'desc' : 'asc'\n    }));\n  };\n\n  const getStatusColor = (status: string) => {\n    const colors = {\n      Lead: 'bg-blue-100 text-blue-800',\n      Prospect: 'bg-yellow-100 text-yellow-800',\n      Customer: 'bg-green-100 text-green-800',\n      Inactive: 'bg-gray-100 text-gray-800',\n    };\n    return colors[status as keyof typeof colors] || colors.Lead;\n  };\n\n  const getPriorityColor = (priority: string) => {\n    const colors = {\n      High: 'text-red-600',\n      Medium: 'text-yellow-600',\n      Low: 'text-green-600',\n    };\n    return colors[priority as keyof typeof colors] || colors.Medium;\n  };\n\n  return (\n    <div className=\"bg-white rounded-lg border\">\n      <Table>\n        <TableHeader>\n          <TableRow>\n            <TableHead className=\"w-12\">\n              <Checkbox\n                checked={selectedContacts.length === contacts.length}\n                onCheckedChange={(checked) => {\n                  if (checked) {\n                    setSelectedContacts(contacts.map(c => c.id));\n                  } else {\n                    setSelectedContacts([]);\n                  }\n                }}\n              />\n            </TableHead>\n            <TableHead \n              className=\"cursor-pointer\"\n              onClick={() => handleSort('firstName')}\n            >\n              <div className=\"flex items-center gap-2\">\n                Name\n                <ArrowUpDownIcon className=\"h-4 w-4\" />\n              </div>\n            </TableHead>\n            <TableHead \n              className=\"cursor-pointer\"\n              onClick={() => handleSort('email')}\n            >\n              <div className=\"flex items-center gap-2\">\n                Email\n                <ArrowUpDownIcon className=\"h-4 w-4\" />\n              </div>\n            </TableHead>\n            <TableHead>Company</TableHead>\n            <TableHead>Status</TableHead>\n            <TableHead>Priority</TableHead>\n            <TableHead \n              className=\"cursor-pointer\"\n              onClick={() => handleSort('lastContactedAt')}\n            >\n              <div className=\"flex items-center gap-2\">\n                Last Contact\n                <ArrowUpDownIcon className=\"h-4 w-4\" />\n              </div>\n            </TableHead>\n            <TableHead>Actions</TableHead>\n          </TableRow>\n        </TableHeader>\n        <TableBody>\n          {sortedContacts.map((contact) => (\n            <TableRow key={contact.id} className=\"cursor-pointer hover:bg-gray-50\">\n              <TableCell>\n                <Checkbox\n                  checked={selectedContacts.includes(contact.id)}\n                  onCheckedChange={(checked) => {\n                    if (checked) {\n                      setSelectedContacts(prev => [...prev, contact.id]);\n                    } else {\n                      setSelectedContacts(prev => prev.filter(id => id !== contact.id));\n                    }\n                  }}\n                />\n              </TableCell>\n              <TableCell onClick={() => onContactSelect(contact)}>\n                <div className=\"flex items-center gap-3\">\n                  <Avatar className=\"h-8 w-8\">\n                    <AvatarImage src={`/api/avatar/${contact.id}`} />\n                    <AvatarFallback>\n                      {`${contact.firstName?.[0] || ''}${contact.lastName?.[0] || ''}`}\n                    </AvatarFallback>\n                  </Avatar>\n                  <div>\n                    <div className=\"font-medium\">\n                      {contact.firstName} {contact.lastName}\n                    </div>\n                    {contact.jobTitle && (\n                      <div className=\"text-sm text-gray-500\">{contact.jobTitle}</div>\n                    )}\n                  </div>\n                </div>\n              </TableCell>\n              <TableCell>\n                {contact.email && (\n                  <a \n                    href={`mailto:${contact.email}`} \n                    className=\"text-blue-600 hover:underline\"\n                    onClick={(e) => e.stopPropagation()}\n                  >\n                    {contact.email}\n                  </a>\n                )}\n              </TableCell>\n              <TableCell>\n                {contact.company || contact.companyName}\n              </TableCell>\n              <TableCell>\n                <Badge className={cn(\"text-xs\", getStatusColor(contact.status))}>\n                  {contact.status}\n                </Badge>\n              </TableCell>\n              <TableCell>\n                <div className={cn(\"font-medium\", getPriorityColor(contact.priority || 'Medium'))}>\n                  {contact.priority || 'Medium'}\n                </div>\n              </TableCell>\n              <TableCell>\n                {contact.lastContactedAt && (\n                  <div className=\"text-sm text-gray-500\">\n                    {formatSmartDate(contact.lastContactedAt)}\n                  </div>\n                )}\n              </TableCell>\n              <TableCell>\n                <DropdownMenu>\n                  <DropdownMenuTrigger asChild>\n                    <Button variant=\"ghost\" size=\"sm\">\n                      <MoreHorizontalIcon className=\"h-4 w-4\" />\n                    </Button>\n                  </DropdownMenuTrigger>\n                  <DropdownMenuContent>\n                    <DropdownMenuItem onClick={() => onContactEdit(contact)}>\n                      <PencilIcon className=\"h-4 w-4 mr-2\" />\n                      Edit\n                    </DropdownMenuItem>\n                    <DropdownMenuItem onClick={() => onContactSelect(contact)}>\n                      <EyeIcon className=\"h-4 w-4 mr-2\" />\n                      View Details\n                    </DropdownMenuItem>\n                    <DropdownMenuSeparator />\n                    <DropdownMenuItem \n                      onClick={() => onContactDelete(contact.id)}\n                      className=\"text-red-600\"\n                    >\n                      <TrashIcon className=\"h-4 w-4 mr-2\" />\n                      Delete\n                    </DropdownMenuItem>\n                  </DropdownMenuContent>\n                </DropdownMenu>\n              </TableCell>\n            </TableRow>\n          ))}\n        </TableBody>\n      </Table>\n    </div>\n  );\n}\n```\n\n### Contact Details Component\n```tsx\ninterface ContactDetailsProps {\n  contact: Contact;\n  onEdit: () => void;\n  onClose: () => void;\n}\n\nexport function ContactDetails({ contact, onEdit, onClose }: ContactDetailsProps) {\n  const { data: activities, isLoading } = api.contact.getActivities.useQuery({\n    contactId: contact.id,\n  });\n\n  const { data: relatedCompany } = api.company.getById.useQuery(\n    { id: contact.companyId! },\n    { enabled: !!contact.companyId }\n  );\n\n  return (\n    <div className=\"space-y-6\">\n      {/* Header */}\n      <div className=\"flex items-start justify-between\">\n        <div className=\"flex items-center gap-4\">\n          <Avatar className=\"h-16 w-16\">\n            <AvatarImage src={`/api/avatar/${contact.id}`} />\n            <AvatarFallback className=\"text-lg\">\n              {`${contact.firstName?.[0] || ''}${contact.lastName?.[0] || ''}`}\n            </AvatarFallback>\n          </Avatar>\n          <div>\n            <h2 className=\"text-2xl font-bold\">\n              {contact.firstName} {contact.lastName}\n            </h2>\n            {contact.jobTitle && (\n              <p className=\"text-gray-600\">{contact.jobTitle}</p>\n            )}\n            {relatedCompany && (\n              <p className=\"text-sm text-blue-600\">\n                at {relatedCompany.name}\n              </p>\n            )}\n          </div>\n        </div>\n        <div className=\"flex items-center gap-2\">\n          <Button variant=\"outline\" onClick={onEdit}>\n            <PencilIcon className=\"h-4 w-4 mr-2\" />\n            Edit\n          </Button>\n          <Button variant=\"ghost\" onClick={onClose}>\n            <XIcon className=\"h-4 w-4\" />\n          </Button>\n        </div>\n      </div>\n\n      {/* Status and Priority */}\n      <div className=\"flex items-center gap-4\">\n        <Badge className={getStatusColor(contact.status)}>\n          {contact.status}\n        </Badge>\n        <div className=\"flex items-center gap-2\">\n          <span className=\"text-sm text-gray-500\">Priority:</span>\n          <span className={cn(\"font-medium\", getPriorityColor(contact.priority || 'Medium'))}>\n            {contact.priority || 'Medium'}\n          </span>\n        </div>\n      </div>\n\n      {/* Contact Information */}\n      <Card>\n        <CardHeader>\n          <CardTitle>Contact Information</CardTitle>\n        </CardHeader>\n        <CardContent className=\"space-y-4\">\n          {contact.email && (\n            <div className=\"flex items-center gap-3\">\n              <MailIcon className=\"h-4 w-4 text-gray-400\" />\n              <a href={`mailto:${contact.email}`} className=\"text-blue-600 hover:underline\">\n                {contact.email}\n              </a>\n            </div>\n          )}\n          {contact.phone && (\n            <div className=\"flex items-center gap-3\">\n              <PhoneIcon className=\"h-4 w-4 text-gray-400\" />\n              <a href={`tel:${contact.phone}`} className=\"text-blue-600 hover:underline\">\n                {formatPhone(contact.phone)}\n              </a>\n            </div>\n          )}\n          {(contact.address || contact.city || contact.state || contact.country) && (\n            <div className=\"flex items-start gap-3\">\n              <MapPinIcon className=\"h-4 w-4 text-gray-400 mt-0.5\" />\n              <div>\n                {contact.address && <div>{contact.address}</div>}\n                <div>\n                  {[contact.city, contact.state, contact.postalCode, contact.country]\n                    .filter(Boolean)\n                    .join(', ')}\n                </div>\n              </div>\n            </div>\n          )}\n        </CardContent>\n      </Card>\n\n      {/* Professional Information */}\n      {(contact.industry || contact.workExperience || contact.skills) && (\n        <Card>\n          <CardHeader>\n            <CardTitle>Professional Information</CardTitle>\n          </CardHeader>\n          <CardContent className=\"space-y-4\">\n            {contact.industry && (\n              <div>\n                <span className=\"text-sm font-medium text-gray-500\">Industry:</span>\n                <p>{contact.industry}</p>\n              </div>\n            )}\n            {contact.workExperience && (\n              <div>\n                <span className=\"text-sm font-medium text-gray-500\">Experience:</span>\n                <p>{contact.workExperience}</p>\n              </div>\n            )}\n            {contact.skills && (\n              <div>\n                <span className=\"text-sm font-medium text-gray-500\">Skills:</span>\n                <p>{contact.skills}</p>\n              </div>\n            )}\n          </CardContent>\n        </Card>\n      )}\n\n      {/* Activity Timeline */}\n      <Card>\n        <CardHeader>\n          <CardTitle>Activity Timeline</CardTitle>\n        </CardHeader>\n        <CardContent>\n          {isLoading ? (\n            <div className=\"space-y-2\">\n              {Array.from({ length: 3 }).map((_, i) => (\n                <Skeleton key={i} className=\"h-16 w-full\" />\n              ))}\n            </div>\n          ) : activities && activities.length > 0 ? (\n            <ActivitySection\n              activities={activities}\n              onCreateActivity={(activity) => {\n                // Handle activity creation\n              }}\n            />\n          ) : (\n            <div className=\"text-center py-8 text-gray-500\">\n              <ActivityIcon className=\"h-8 w-8 mx-auto mb-2 opacity-50\" />\n              <p>No activities yet</p>\n              <Button variant=\"outline\" size=\"sm\" className=\"mt-2\">\n                Add first activity\n              </Button>\n            </div>\n          )}\n        </CardContent>\n      </Card>\n\n      {/* Notes */}\n      {contact.remark && (\n        <Card>\n          <CardHeader>\n            <CardTitle>Notes</CardTitle>\n          </CardHeader>\n          <CardContent>\n            <p className=\"whitespace-pre-wrap\">{contact.remark}</p>\n          </CardContent>\n        </Card>\n      )}\n    </div>\n  );\n}\n```\n\n## Company Management\n\n### Company List and Details\n```tsx\nexport function CompanyList({ companies, onCompanySelect }: CompanyListProps) {\n  return (\n    <div className=\"grid gap-4 md:grid-cols-2 lg:grid-cols-3\">\n      {companies.map((company) => (\n        <Card \n          key={company.id} \n          className=\"cursor-pointer hover:shadow-md transition-shadow\"\n          onClick={() => onCompanySelect(company)}\n        >\n          <CardContent className=\"p-6\">\n            <div className=\"flex items-start justify-between mb-4\">\n              <div className=\"flex items-center gap-3\">\n                <Avatar className=\"h-10 w-10\">\n                  <AvatarImage src={`/api/company-logo/${company.id}`} />\n                  <AvatarFallback>\n                    {company.name.substring(0, 2).toUpperCase()}\n                  </AvatarFallback>\n                </Avatar>\n                <div>\n                  <h3 className=\"font-semibold\">{company.name}</h3>\n                  {company.industry && (\n                    <p className=\"text-sm text-gray-500\">{company.industry}</p>\n                  )}\n                </div>\n              </div>\n              <Badge \n                variant={company.status === 'active' ? 'default' : 'secondary'}\n                className=\"text-xs\"\n              >\n                {company.status}\n              </Badge>\n            </div>\n            \n            {company.description && (\n              <p className=\"text-sm text-gray-600 mb-4 line-clamp-2\">\n                {company.description}\n              </p>\n            )}\n            \n            <div className=\"space-y-2 text-xs text-gray-500\">\n              {company.size && (\n                <div className=\"flex items-center gap-2\">\n                  <UsersIcon className=\"h-3 w-3\" />\n                  {company.size} employees\n                </div>\n              )}\n              {company.website && (\n                <div className=\"flex items-center gap-2\">\n                  <GlobeIcon className=\"h-3 w-3\" />\n                  <a \n                    href={company.website} \n                    target=\"_blank\" \n                    rel=\"noopener noreferrer\"\n                    className=\"text-blue-600 hover:underline\"\n                    onClick={(e) => e.stopPropagation()}\n                  >\n                    {new URL(company.website).hostname}\n                  </a>\n                </div>\n              )}\n              {company.city && company.country && (\n                <div className=\"flex items-center gap-2\">\n                  <MapPinIcon className=\"h-3 w-3\" />\n                  {company.city}, {company.country}\n                </div>\n              )}\n            </div>\n          </CardContent>\n        </Card>\n      ))}\n    </div>\n  );\n}\n```\n\n## tRPC Routers\n\n### Contact Router\n```typescript\n// server/routers/contact/index.ts\nimport { z } from 'zod';\nimport { createTRPCRouter, protectedProcedure } from '@/server/trpc';\nimport { contact, companyContact } from '@/drizzle/schema';\nimport { eq, and, like, or, desc, asc } from 'drizzle-orm';\nimport { createContactActivityHelper } from '@/server/helper/contact';\n\nconst contactFilterSchema = z.object({\n  limit: z.number().min(1).max(100).default(50),\n  offset: z.number().min(0).default(0),\n  search: z.string().optional(),\n  status: z.string().optional(),\n  assignedTo: z.string().optional(),\n  companyId: z.string().optional(),\n  sortBy: z.enum(['firstName', 'lastName', 'email', 'createdAt', 'lastContactedAt']).default('createdAt'),\n  sortOrder: z.enum(['asc', 'desc']).default('desc'),\n});\n\nconst createContactSchema = z.object({\n  firstName: z.string().min(1),\n  lastName: z.string(),\n  email: z.string().email().optional(),\n  phone: z.string().optional(),\n  company: z.string().optional(),\n  companyId: z.string().optional(),\n  jobTitle: z.string().optional(),\n  status: z.string().default('Lead'),\n  priority: z.enum(['High', 'Medium', 'Low']).default('Medium'),\n  source: z.string().optional(),\n  remark: z.string().optional(),\n  // ... other contact fields\n});\n\nexport const contactRouter = createTRPCRouter({\n  // Get contacts with filtering and pagination\n  getAll: protectedProcedure\n    .input(contactFilterSchema)\n    .query(async ({ ctx, input }) => {\n      const conditions = [];\n      \n      // Search across name and email\n      if (input.search) {\n        conditions.push(\n          or(\n            like(contact.firstName, `%${input.search}%`),\n            like(contact.lastName, `%${input.search}%`),\n            like(contact.email, `%${input.search}%`),\n            like(contact.company, `%${input.search}%`)\n          )\n        );\n      }\n      \n      if (input.status) {\n        conditions.push(eq(contact.status, input.status));\n      }\n      \n      if (input.assignedTo) {\n        conditions.push(eq(contact.assignedTo, input.assignedTo));\n      }\n      \n      if (input.companyId) {\n        conditions.push(eq(contact.companyId, input.companyId));\n      }\n\n      const whereClause = conditions.length > 0 ? and(...conditions) : undefined;\n      const orderBy = input.sortOrder === 'asc' \n        ? asc(contact[input.sortBy]) \n        : desc(contact[input.sortBy]);\n\n      const [contacts, totalCount] = await Promise.all([\n        ctx.db\n          .select({\n            ...contact,\n            companyName: company.name,\n          })\n          .from(contact)\n          .leftJoin(company, eq(contact.companyId, company.id))\n          .where(whereClause)\n          .orderBy(orderBy)\n          .limit(input.limit)\n          .offset(input.offset),\n        ctx.db\n          .select({ count: count() })\n          .from(contact)\n          .where(whereClause)\n      ]);\n\n      return {\n        data: contacts,\n        total: totalCount[0]?.count || 0,\n        hasMore: input.offset + input.limit < (totalCount[0]?.count || 0),\n      };\n    }),\n\n  // Get single contact by ID\n  getById: protectedProcedure\n    .input(z.object({ id: z.string() }))\n    .query(async ({ ctx, input }) => {\n      const contactData = await ctx.db\n        .select({\n          ...contact,\n          companyName: company.name,\n        })\n        .from(contact)\n        .leftJoin(company, eq(contact.companyId, company.id))\n        .where(eq(contact.id, input.id))\n        .limit(1);\n\n      if (!contactData[0]) {\n        throw new Error('Contact not found');\n      }\n\n      return contactData[0];\n    }),\n\n  // Create new contact\n  create: protectedProcedure\n    .input(createContactSchema)\n    .mutation(async ({ ctx, input }) => {\n      const newContact = await ctx.db.insert(contact).values({\n        id: crypto.randomUUID(),\n        ...input,\n        name: `${input.firstName} ${input.lastName}`.trim(),\n        createdBy: ctx.session.user.id,\n        assignedTo: ctx.session.user.id, // Auto-assign to creator\n        createdAt: new Date(),\n        updatedAt: new Date(),\n      }).returning();\n\n      // Create activity log\n      await createContactActivityHelper(\n        ctx.session.user.id,\n        newContact[0].id,\n        'created',\n        `${input.firstName} ${input.lastName}`\n      );\n\n      return newContact[0];\n    }),\n\n  // Update contact\n  update: protectedProcedure\n    .input(z.object({\n      id: z.string(),\n      ...createContactSchema.partial(),\n    }))\n    .mutation(async ({ ctx, input }) => {\n      const { id, ...updates } = input;\n      \n      const updatedContact = await ctx.db\n        .update(contact)\n        .set({\n          ...updates,\n          name: updates.firstName || updates.lastName \n            ? `${updates.firstName || ''} ${updates.lastName || ''}`.trim()\n            : undefined,\n          updatedAt: new Date(),\n        })\n        .where(eq(contact.id, id))\n        .returning();\n\n      if (!updatedContact[0]) {\n        throw new Error('Contact not found');\n      }\n\n      return updatedContact[0];\n    }),\n\n  // Delete contact\n  delete: protectedProcedure\n    .input(z.object({ id: z.string() }))\n    .mutation(async ({ ctx, input }) => {\n      const deletedContact = await ctx.db\n        .delete(contact)\n        .where(eq(contact.id, input.id))\n        .returning();\n\n      if (!deletedContact[0]) {\n        throw new Error('Contact not found');\n      }\n\n      return { success: true };\n    }),\n\n  // Get contact activities\n  getActivities: protectedProcedure\n    .input(z.object({ contactId: z.string() }))\n    .query(async ({ ctx, input }) => {\n      // Implementation for getting contact activities\n      // This would join with activity tables\n    }),\n\n  // Update contact status\n  updateStatus: protectedProcedure\n    .input(z.object({\n      id: z.string(),\n      status: z.string(),\n    }))\n    .mutation(async ({ ctx, input }) => {\n      const updated = await ctx.db\n        .update(contact)\n        .set({ \n          status: input.status, \n          updatedAt: new Date(),\n          ...(input.status === 'Customer' && { joinedAt: new Date() })\n        })\n        .where(eq(contact.id, input.id))\n        .returning();\n\n      return updated[0];\n    }),\n\n  // Bulk operations\n  bulkUpdate: protectedProcedure\n    .input(z.object({\n      contactIds: z.array(z.string()),\n      updates: createContactSchema.partial(),\n    }))\n    .mutation(async ({ ctx, input }) => {\n      const updated = await ctx.db\n        .update(contact)\n        .set({\n          ...input.updates,\n          updatedAt: new Date(),\n        })\n        .where(inArray(contact.id, input.contactIds))\n        .returning();\n\n      return updated;\n    }),\n});\n```\n\n## Best Practices\n\n### Data Management\n- Maintain data consistency across related entities\n- Implement proper validation and error handling\n- Use transactions for multi-table operations\n- Regular data cleanup and deduplication\n\n### User Experience\n- Provide intuitive search and filtering\n- Implement bulk operations for efficiency\n- Show relevant context and relationships\n- Use progressive disclosure for complex forms\n\n### Performance\n- Implement efficient pagination\n- Use proper database indexing\n- Cache frequently accessed data\n- Optimize complex queries\n\n### Security\n- Implement proper access controls\n- Validate all user inputs\n- Audit sensitive operations\n- Protect personal information