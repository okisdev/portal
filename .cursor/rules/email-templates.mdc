## Email Sending Patterns

### Welcome Email Integration
```typescript
// server/routers/auth.ts
import { sendEmail } from '@/lib/mail';
import { WelcomeEmail } from '@/emails/welcome';

export const authRouter = createTRPCRouter({
  register: publicProcedure
    .input(registerSchema)
    .mutation(async ({ ctx, input }) => {
      // Create user account
      const user = await ctx.db.insert(userTable).values({
        ...input,
        id: crypto.randomUUID(),
      });

      // Send welcome email
      await sendEmail({
        to: input.email,
        subject: 'Welcome to Portal!',
        react: WelcomeEmail({
          name: input.name,
          email: input.email,
          loginUrl: `${env.APP_URL}/login`,
        }),
      });

      return { success: true };
    }),
});
```

### Bulk Email Sending
```typescript
export async function sendBulkEmails<T>(
  recipients: { email: string; props: T }[],
  template: (props: T) => ReactElement,
  subject: string
) {
  const promises = recipients.map(({ email, props }) =>
    sendEmail({
      to: email,
      subject,
      react: template(props),
    })
  );

  // Send emails in batches to avoid rate limits
  const batchSize = 10;
  const batches = [];
  
  for (let i = 0; i < promises.length; i += batchSize) {
    batches.push(promises.slice(i, i + batchSize));
  }

  const results = [];
  for (const batch of batches) {
    const batchResults = await Promise.allSettled(batch);
    results.push(...batchResults);
    
    // Add delay between batches
    await new Promise(resolve => setTimeout(resolve, 1000));
  }

  return results;
}
```

