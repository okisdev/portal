import { render } from '@react-email/render';
import type { ReactElement } from 'react';

export interface SendEmailParams {
  to: string | string[];
  from?: string;
  subject: string;
  content: string;
  cc?: string[];
  bcc?: string[];
  attachments?: any[];
}

export async function sendHtmlEmail({
  from = 'Portal <noreply@portal.vifu.org>',
  to,
  subject,
  content,
  cc,
  bcc,
  attachments,
}: SendEmailParams) {
  // Implementation depends on email service provider
  // This is a generic interface that can be adapted
}

export function renderEmailTemplate(template: ReactElement): string {
  return render(template);
}

export async function sendTemplateEmail<T>(
  template: (props: T) => ReactElement,
  props: T,
  emailOptions: Omit<EmailOptions, 'react'>
) {
  const rendered = template(props);
  
  return sendEmail({
    ...emailOptions,
    react: rendered,
  });
}
