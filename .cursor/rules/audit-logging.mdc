## Audit Reporting

### Audit Router
```typescript
// server/routers/audit.ts
import { z } from 'zod';
import { createTRPCRouter, protectedProcedure, adminProcedure } from '@/server/trpc';
import { auditLog } from '@/drizzle/schema';
import { desc, eq, and, gte, lte, like } from 'drizzle-orm';

const auditQuerySchema = z.object({
  limit: z.number().min(1).max(100).default(50),
  offset: z.number().min(0).default(0),
  userId: z.string().optional(),
  resource: z.string().optional(),
  action: z.enum(['CREATE', 'READ', 'UPDATE', 'DELETE']).optional(),
  status: z.enum(['SUCCESS', 'FAILED']).optional(),
  startDate: z.date().optional(),
  endDate: z.date().optional(),
  search: z.string().optional(),
});

export const auditRouter = createTRPCRouter({
  // Get audit logs (admin only)
  getLogs: adminProcedure
    .input(auditQuerySchema)
    .query(async ({ ctx, input }) => {
      const conditions = [];

      if (input.userId) conditions.push(eq(auditLog.userId, input.userId));
      if (input.resource) conditions.push(eq(auditLog.resource, input.resource));
      if (input.action) conditions.push(eq(auditLog.action, input.action));
      if (input.status) conditions.push(eq(auditLog.status, input.status));
      if (input.startDate) conditions.push(gte(auditLog.timestamp, input.startDate));
      if (input.endDate) conditions.push(lte(auditLog.timestamp, input.endDate));
      if (input.search) {
        conditions.push(
          like(auditLog.inputData, `%${input.search}%`)
        );
      }

      const whereClause = conditions.length > 0 ? and(...conditions) : undefined;

      const logs = await ctx.db
        .select()
        .from(auditLog)
        .where(whereClause)
        .orderBy(desc(auditLog.timestamp))
        .limit(input.limit)
        .offset(input.offset);

      const total = await ctx.db
        .select({ count: count() })
        .from(auditLog)
        .where(whereClause);

      return {
        data: logs,
        total: total[0]?.count || 0,
        hasMore: input.offset + input.limit < (total[0]?.count || 0),
      };
    }),

  // Get user's own audit trail
  getMyLogs: protectedProcedure
    .input(auditQuerySchema.omit({ userId: true }))
    .query(async ({ ctx, input }) => {
      // Same as above but filtered to current user
      const logs = await ctx.db
        .select()
        .from(auditLog)
        .where(eq(auditLog.userId, ctx.session.user.id))
        .orderBy(desc(auditLog.timestamp))
        .limit(input.limit)
        .offset(input.offset);

      return { data: logs };
    }),

  // Get audit statistics
  getStats: adminProcedure
    .input(z.object({
      startDate: z.date(),
      endDate: z.date(),
    }))
    .query(async ({ ctx, input }) => {
      // Implementation for audit statistics
      // Count by action, resource, status, etc.
    }),
});
```

## Best Practices

### What to Log
- All data modifications (CREATE, UPDATE, DELETE)
- Authentication events (login, logout, failed attempts)
- Permission changes and role updates
- API key usage and access
- File uploads and downloads
- System configuration changes

### Security Considerations
- Never log sensitive data (passwords, tokens, PII)
- Sanitize input data before logging
- Implement log retention policies
- Secure audit log storage and access
- Monitor for audit log tampering

### Performance Optimization
- Use asynchronous logging to avoid blocking operations
- Implement log batching for high-volume operations
- Use proper database indexing for audit queries
- Archive old logs to separate storage

### Compliance
- Maintain immutable audit trails
- Implement proper data retention policies
- Provide audit reporting capabilities
- Support compliance export formats (CSV, JSON)
- Document audit trail procedures